{
  "name": "naamase-api",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "tsx src/export-faceit.ts",
    "dev": "tsx watch src/export-faceit.ts",
    "start:cfg": "tsx src/export-faceit.ts --config faceit.config.json",
    "playbook": "tsx src/playbook.ts",
    "preview": "tsx src/preview.ts",
    "init": "tsx src/init.ts --config faceit.config.json",
    "diag:standings": "tsx src/diagnose-standings.ts --config faceit.config.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "check:format": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/node": "^26.0.0",
    "csv-stringify": "^6.8.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --max-warnings=0"
    ],
    "*.{ts,tsx,js,css,md,json,yml,yaml}": [
      "prettier --check"
    ]
  }
}
