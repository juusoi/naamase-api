{
  "name": "naamase-api",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/export-faceit.ts",
    "dev": "tsx watch src/export-faceit.ts",
    "start:cfg": "tsx src/export-faceit.ts --config faceit.config.json",
    "preview": "tsx src/preview.ts",
    "init": "tsx src/init.ts --config faceit.config.json",
    "diag:standings": "tsx src/diagnose-standings.ts --config faceit.config.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "check:format": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/node": "^24.8.1",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.2.3",
    "tsx": "^4.20.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --max-warnings=0"
    ],
    "*.{ts,tsx,js,css,md,json,yml,yaml}": [
      "prettier --check"
    ]
  }
}
